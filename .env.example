# Конфігурація адмін бота
# Скопіюйте у .env та заповніть значення

# ========================================
# АДМІН БОТ
# ========================================
ADMIN_BOT_TOKEN=PUT_TELEGRAM_ADMIN_BOT_TOKEN
ADMIN_BOT_ADMIN_ID=PUT_YOUR_TELEGRAM_USER_ID

# Назва systemd сервісу цього адмін бота (для самоперезапуску)
ADMIN_BOT_SELF_SERVICE=admin_bot

# Список цілей через кому, якими цей адмін бот може керувати
ADMIN_TARGETS=generator,inventory

# ========================================
# WATCHDOG ТА СПОВІЩЕННЯ (НОВЕ в v6.1)
# ========================================
# Увімкнути автоматичний моніторинг та сповіщення
ADMIN_BOT_ALERTS_ENABLED=false

# Інтервал моніторингу в секундах (за замовчуванням: 300 = 5 хвилин)
ADMIN_BOT_ALERT_INTERVAL=300

# Надсилати сповіщення про критичні помилки в логах (за замовчуванням: true)
ADMIN_BOT_ALERT_ON_CRITICAL=true

# ========================================
# САМООНОВЛЕННЯ (Опціонально)
# ========================================
# Git URL для кнопки самооновлення (опціонально)
# ADMIN_BOT_GIT_URL=https://github.com/imeromua/admin_bot.git
# ADMIN_BOT_GIT_BRANCH=main

# ========================================
# ЦІЛЬ: generator
# ========================================
# Назва systemd сервісу
ADMIN_TARGET_GENERATOR_SERVICE=generator_bot
# Абсолютний шлях до проєкту на сервері
ADMIN_TARGET_GENERATOR_PATH=/home/anubis/generator_bot
# Опціонально: URL репозиторію (метадані)
ADMIN_TARGET_GENERATOR_REPO=https://github.com/imeromua/generator_bot.git
# Опціонально: python виконуваний файл venv цілі (використовується для pip install/freeze/outdated)
ADMIN_TARGET_GENERATOR_PYTHON=/home/anubis/generator_bot/.venv/bin/python

# Опціональні перевизначення (за замовчуванням визначаються з PATH)
# ADMIN_TARGET_GENERATOR_ENV_FILE=/home/anubis/generator_bot/.env
# ADMIN_TARGET_GENERATOR_REQ_FILE=/home/anubis/generator_bot/requirements.txt
# ADMIN_TARGET_GENERATOR_LOG_FILE=/home/anubis/generator_bot/bot.log

# ========================================
# ЦІЛЬ: inventory
# ========================================
ADMIN_TARGET_INVENTORY_SERVICE=inventory_bot
ADMIN_TARGET_INVENTORY_PATH=/home/anubis/inventory_bot
ADMIN_TARGET_INVENTORY_REPO=https://github.com/imeromua/inventory_bot.git
ADMIN_TARGET_INVENTORY_PYTHON=/home/anubis/inventory_bot/.venv/bin/python

# Опціональні перевизначення (за замовчуванням визначаються з PATH)
# ADMIN_TARGET_INVENTORY_ENV_FILE=/home/anubis/inventory_bot/.env
# ADMIN_TARGET_INVENTORY_REQ_FILE=/home/anubis/inventory_bot/requirements.txt
# ADMIN_TARGET_INVENTORY_LOG_FILE=/home/anubis/inventory_bot/bot.log
